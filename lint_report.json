d-500\" />;\n      case 'TASK_UPDATED': return <RotateCw className=\"w-4 h-4 text-amber-500\" />;\n      case 'TASK_DELETED': return <Trash2 className=\"w-4 h-4 text-rose-500\" />;\n      case 'AI_ASSIGNED': return <Zap className=\"w-4 h-4 text-indigo-500\" />;\n      case 'VOICE_TASK_CREATED': return <Mic className=\"w-4 h-4 text-indigo-400\" />;\n      default: return <Target className=\"w-4 h-4 text-zinc-400\" />;\n    }\n  };\n\n  const formatTimestamp = (date: string) => {\n    return new Date(date).toLocaleTimeString('he-IL', {\n      hour: '2-digit',\n      minute: '2-digit'\n    });\n  };\n\n  return (\n    <div className=\"bg-zinc-900/40 border border-white/5 rounded-3xl overflow-hidden backdrop-blur-md\">\n      <div className=\"px-6 py-4 border-b border-white/5 flex items-center justify-between\">\n        <h2 className=\"text-sm font-bold text-zinc-400 uppercase tracking-widest flex items-center gap-2\">\n          <Clock className=\"w-4 h-4\" />\n          פעילות צוות&rlm;\n        </h2>\n        <span className=\"w-2 h-2 bg-emerald-500 rounded-full animate-pulse shadow-[0_0_8px_rgba(16,185,129,0.5)]\" />\n      </div>\n\n      <div className=\"p-4 space-y-4 max-h-[500px] overflow-y-auto custom-scrollbar\">\n        {activities.length === 0 ? (\n          <div className=\"py-10 text-center text-zinc-500 text-sm\">אין פעילויות אחרונות&rlm;</div>\n        ) : (\n          activities.map((activity: any) => (\n            <div key={activity._id} className=\"relative pl-6 pb-2 border-l border-white/5 last:pb-0\">\n              <div className=\"absolute -left-[9px] top-1 bg-zinc-950 p-1\">\n                {getActionIcon(activity.action)}\n              </div>\n              \n              <div className=\"flex flex-col gap-1\">\n                <div className=\"flex items-center justify-between\">\n                  <span className=\"text-xs font-bold text-white\">\n                    {activity.userId?.name || 'מתחבר אנונימי'}\n                  </span>\n                  <span className=\"text-[10px] text-zinc-500\">\n                    {formatTimestamp(activity.timestamp)}\n                  </span>\n                </div>\n                <p className=\"text-xs text-zinc-400 leading-relaxed\">\n                  {activity.details || activity.action.replace(/_/g, ' ')}\n                </p>\n              </div>\n            </div>\n          ))\n        )}\n      </div>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Lenovo\\Desktop\\App\\TaskFlow AI\\web\\src\\components\\ui\\AIPulseIndicator.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Lenovo\\Desktop\\App\\TaskFlow AI\\web\\src\\components\\ui\\SkillBadge.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Lenovo\\Desktop\\App\\TaskFlow AI\\web\\src\\components\\users\\UserSkillsManager.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Lenovo\\Desktop\\App\\TaskFlow AI\\web\\src\\hooks\\useSmartInput.ts","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":1,"message":"Unexpected any. Specify a different type.","line":11,"column":33,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":11,"endColumn":36,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[495,498],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[495,498],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}